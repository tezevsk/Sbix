{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Sbix",
    "scopeName": "tezevsk.sbix",
    "fileTypes": [
        "sbix",
        "sbx",
        "sbixci"
    ],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.sbix",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.sbix",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },    
        "keywords": {
                "patterns": [
                    {
                        "name": "keyword.control.import.sbix",
                        "match": "\\b(bring)\\b"
                    },
                    {
                        "name": "keyword.control.directive.sbix",
                        "match": "\\b(extern)\\b"
                    },
                    {
                        "name": "keyword.control.sbix",
                        "match": "\\b(if|else|while|for|return|break|continue)\\b"
                    },
                    {
                        "name": "keyword.declaration.sbix",
                        "match": "\\b(let|const|function|class)\\b"
                    },
                    {
                        "name": "constant.language.boolean.sbix",
                        "match": "\\b(true|false)\\b"
                    }
                ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.sbix",
                    "match": "\\b(int|float32|float|string|bool|ptr|items)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.sbix",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.sbix",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.sbix",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.sbix",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.sbix",
                    "match": "\\+=|-=|\\*=|/=|="
                },
                {
                    "name": "keyword.operator.arithmetic.sbix",
                    "match": "\\+\\+|--|\\+|-|\\*|/|%"
                },
                {
                    "name": "keyword.operator.logical.sbix",
                    "match": "&&|\\|\\||!"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.sbix",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        }
    }
}